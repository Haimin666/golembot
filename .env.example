# Golem development/testing environment config template
# Copy this file to .env and fill in real values: cp .env.example .env

# Cursor Agent API Key — required for headless e2e tests
# Obtain: Cursor Settings → API Keys, or `agent auth token`
CURSOR_API_KEY=

# Anthropic API Key — required for Claude Code engine e2e tests
# Obtain: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Golem HTTP service Bearer Token (optional, auto-generated during tests)
# GOLEM_TOKEN=
